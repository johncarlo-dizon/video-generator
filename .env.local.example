# ============================================================
# AI VIDEO GENERATOR - ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your keys
# ============================================================

# GROQ API KEY (FREE - get at console.groq.com)
# Model used: llama-3.1-8b-instant (fastest, 14,400 req/day free)
# For better quality switch to: llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here

# GROQ MODEL SELECTION
# llama-3.1-8b-instant   → Fast, 14,400 req/day, best for volume
# llama-3.3-70b-versatile → Smarter, 1,000 req/day
# meta-llama/llama-4-scout-17b-16e-instruct → Latest, 1,000 req/day
GROQ_MODEL=llama-3.3-70b-versatile

# PEXELS API KEY (FREE - get at pexels.com/api)
# Limit: 200 req/hour, 20,000 req/month - completely free
PEXELS_API_KEY=your_pexels_api_key_here

# ELEVENLABS API KEY (FREE TIER - get at elevenlabs.io)
# Free: 10,000 characters/month
# Leave empty to use gTTS (unlimited, lower quality)
ELEVENLABS_API_KEY=

# TTS MODE: "elevenlabs" | "gtts" (default: gtts = unlimited free)
TTS_MODE=gtts

# App settings
NEXT_PUBLIC_APP_NAME=AI Video Generator
MAX_VIDEO_DURATION=60
